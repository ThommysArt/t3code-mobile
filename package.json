{
  "name": "@t3tools/mobile",
  "version": "0.0.6",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "bash scripts/check-dev-environment.sh && expo start --clear",
    "dev:unsafe": "expo start --clear",
    "fix:inotify": "bash scripts/increase-inotify-limit.sh",
    "clean:metro": "rm -rf /tmp/metro-file-map-* /tmp/metro-cache /tmp/haste-map-* .expo/metro .expo/web node_modules/.cache && echo 'Metro caches cleared. Restart with: pnpm dev'",
    "start": "bash scripts/check-dev-environment.sh && expo start",
    "prebuild": "CI=1 EXPO_NO_GIT_STATUS=1 expo prebuild --platform android",
    "prebuild:clean": "CI=1 EXPO_NO_GIT_STATUS=1 expo prebuild --clean --platform android",
    "android": "expo run:android",
    "ios": "CI=1 EXPO_NO_GIT_STATUS=1 expo prebuild --platform ios && expo run:ios",
    "build:dev": "bash scripts/build-android-local.sh --dev",
    "build:preview": "bash scripts/build-android-local.sh --preview",
    "install:dev": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "install:preview": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "eas:build:preview": "pnpm dlx eas-cli build --profile preview --platform all",
    "eas:build:preview:local": "pnpm dlx eas-cli build --profile preview --platform all --local",
    "deploy:android": "bash scripts/deploy-android.sh",
    "deploy:android:local": "bash scripts/deploy-android.sh --local",
    "release:android": "bash scripts/deploy-android.sh --release",
    "release:android:local": "bash scripts/deploy-android.sh --release --local",
    "build:android": "bash scripts/deploy-android.sh --build-only",
    "build:android:local": "bash scripts/deploy-android.sh --build-only --local",
    "eas:build:preview:android": "pnpm dlx eas-cli build --profile preview-android --platform android",
    "eas:build:preview:android:local": "bash scripts/build-android-local.sh --preview",
    "eas:build:preview:android:eas-local": "pnpm dlx eas-cli build --profile preview-android --platform android --local",
    "eas:build:preview:ios": "pnpm dlx eas-cli build --profile preview --platform ios",
    "eas:build:preview:ios:local": "pnpm dlx eas-cli build --profile preview --platform ios --local",
    "eas:build:preview:ios:simulator": "pnpm dlx eas-cli build --profile preview-ios-simulator --platform ios",
    "eas:build:preview:ios:simulator:local": "pnpm dlx eas-cli build --profile preview-ios-simulator --platform ios --local"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.78",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/geist-mono": "^0.4.3",
    "@expo/metro-runtime": "~57.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@t3tools/client-runtime": "workspace:*",
    "@t3tools/contracts": "workspace:*",
    "@t3tools/shared": "workspace:*",
    "effect": "4.0.0-beta.78",
    "expo": "^57.0.4",
    "expo-blur": "~57.0.0",
    "expo-camera": "~57.0.1",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.1",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "heroui-native": "^1.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-android-widget": "0.21.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-markdown-display": "7.0.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "uniwind": "^1.9.0",
    "whatwg-fetch": "3.6.20"
  },
  "devDependencies": {
    "@types/react": "~19.2.15",
    "babel-preset-expo": "~57.0.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": "^24.13.1"
  },
  "packageManager": "pnpm@10.24.0"
}
