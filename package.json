{
  "name": "@t3tools/mobile",
  "version": "0.0.6",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "bash scripts/check-dev-environment.sh && expo start --clear",
    "dev:unsafe": "expo start --clear",
    "fix:inotify": "bash scripts/increase-inotify-limit.sh",
    "start": "bash scripts/check-dev-environment.sh && expo start",
    "android": "EXPO_NO_GIT_STATUS=1 expo prebuild --clean --platform android && expo run:android",
    "ios": "EXPO_NO_GIT_STATUS=1 expo prebuild --clean --platform ios && expo run:ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "eas:build:preview": "pnpm dlx eas-cli build --profile preview --platform all",
    "deploy:android": "bash scripts/deploy-android.sh",
    "release:android": "bash scripts/deploy-android.sh --release",
    "eas:build:preview:android": "pnpm dlx eas-cli build --profile preview-android --platform android",
    "eas:build:preview:ios": "pnpm dlx eas-cli build --profile preview --platform ios",
    "eas:build:preview:ios:simulator": "pnpm dlx eas-cli build --profile preview-ios-simulator --platform ios"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.78",
    "@expo/metro-runtime": "~57.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@t3tools/client-runtime": "workspace:*",
    "@t3tools/contracts": "workspace:*",
    "@t3tools/shared": "workspace:*",
    "effect": "4.0.0-beta.78",
    "expo": "^57.0.4",
    "expo-blur": "~57.0.0",
    "expo-camera": "~57.0.1",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "heroui-native": "^1.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-markdown-display": "7.0.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "uniwind": "^1.9.0",
    "whatwg-fetch": "3.6.20"
  },
  "devDependencies": {
    "@types/react": "~19.2.15",
    "babel-preset-expo": "~57.0.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": "^24.13.1"
  },
  "packageManager": "pnpm@10.24.0"
}
