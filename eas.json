{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "24.13.1",
      "pnpm": "10.24.0",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "24.13.1",
      "pnpm": "10.24.0",
      "android": {
        "buildType": "apk"
      }
    },
    "preview-android": {
      "extends": "preview",
      "credentialsSource": "local"
    },
    "preview-ios-simulator": {
      "extends": "preview",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "24.13.1",
      "pnpm": "10.24.0"
    }
  },
  "submit": {
    "production": {}
  }
}